# Codespaces environment template (sanitized)
# This is a COMPLETE KEY TEMPLATE. Populate secrets via GitHub Codespaces secrets or locally.
# DO NOT commit real secrets to this file. Leave values empty or use placeholders.
# The generator script will populate values from:
#   1. GitHub Codespaces/Environment secrets (runtime env vars)
#   2. Existing .env file (case-insensitive fallback)

###########################
# CORE POSTGRESQL DATABASE
###########################
POSTGRES_USER=root
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

###########################
# N8N CORE & ENCRYPTION
###########################
N8N_ENCRYPTION_KEY=
N8N_USER_MANAGEMENT_JWT_SECRET=
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

###########################
# N8N SERVER CONFIGURATION
###########################
N8N_PROTOCOL=http
N8N_HOST=localhost
N8N_PORT=5678
N8N_EDITOR_BASE_URL=
WEBHOOK_URL=
N8N_MODE=true
N8N_API_URL=http://localhost:5678
N8N_API_KEY=
N8N_BASIC_AUTH_ACTIVE=false
N8N_USER_DATA_DIR=./n8n-data
N8N_PUBLIC_API_DISABLED=false
N8N_PUBLIC_API_SWAGGERUI_DISABLED=false
N8N_DISABLE_UI_SHARING=false
N8N_AI_ASSISTANT_BASE_URL=https://ai-assistant.n8n.io

###########################
# DATABASE (Agent Framework Tracing)
###########################
DB_TYPE=postgresdb
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_HOST=localhost
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_DATABASE=n8n

###########################
# OPENTELEMETRY / VSCODE AI TOOLKIT
###########################
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_SERVICE_NAME=ai-agent-system
OTEL_SERVICE_VERSION=1.0.0
ENABLE_TELEMETRY=true
ENABLE_SENSITIVE_DATA=false

###########################
# AI MODEL CONFIGURATION
###########################
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

###########################
# AGENT CONFIGURATION
###########################
AGENT_NAME=ai-agent
AGENT_DESCRIPTION=AI agent with tracing capabilities
AGENT_APPROVE_TOOL_CALLS=false
KNOWLEDGE_DIR=./Knowledge

###########################
# OPTIONAL SERVICE ENDPOINTS
###########################
OLLAMA_HOST=ollama:11434
MCP_SERVER_URL=

###########################
# OPENAI & DEEPSEEK (Claude Flow)
###########################
openai_API_Key=
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_API_KEY=
CLAUDE_MODEL=deepseek-chat

###########################
# GITHUB
###########################
GITHUB_PERSONAL_ACCESS_TOKEN=
github_pat_extended=

###########################
# GITLAB
###########################
gitlab_pat=

###########################
# GOOGLE AI / GEMINI
###########################
GEMINI_API_KEY=
GOOGLE_AI_STUDIO_KEY=
GOOGLE_PROJECT_ID=
GOOGLE_PROJECT_NUMBER=

###########################
# HUGGING FACE
###########################
HUGGING_FACE_TOKEN=

###########################
# JULES API
###########################
JULES_API_KEY=
JULES_RENDR_API_KEY=

###########################
# CODESPACE METADATA
###########################
CODESPACE_NAME=
CODESPACE_DOMAIN=app.github.dev
CODESPACE_N8N_ADMIN=

###########################
# MCP & AGENT MODE INTEGRATIONS
###########################
AGENTMODE_MCP_API_KEY=
CONTEXT7_API_KEY=
CONTEXTSTREAM_API_URL=https://api.contextstream.io
CONTEXTSTREAM_API_KEY=
MCP_MODE=stdio
MCP_SERVER_URL=http://localhost:8080
N8N_MCP_ENDPOINT=
N8N_MCP_TOKEN=

###########################
# RUNTIME & LOGGING
###########################
NODE_ENV=development
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/agents.log

###########################
# OPTIONAL SERVICE ENDPOINTS
###########################
OLLAMA_HOST=ollama:11434

###########################
# DOCUMENTATION & IMPLEMENTATION
###########################
# TO_RUN_GUI_DEMO: genui02 demo via uvicorn genui_workflow:app --port 8008 --reload

###########################
# DEVELOPMENT NOTES
###########################
# 1. This template should be committed to VCS (without secrets).
# 2. Populate values via:
#    - GitHub Codespaces: Settings > Secrets > Repository/Environment secrets
#    - Workspace: Settings > Secrets
#    - Local: copy to .env and update with real values (DO NOT commit .env)
# 3. At Codespaces startup, the devcontainer generator script will:
#    a. Read this template
#    b. Populate from runtime env vars (from Codespaces secrets)
#    c. Fall back to existing .env for any remaining values
#    d. Write a runtime .env for the session
# 4. All keys from workspace .env are automatically discovered and merged
