{
  "servers": {
    "n8n-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "n8n-mcp"
      ],
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "MCP_MODE": "stdio",
        "N8N_MODE": "true",
        "LOG_LEVEL": "info",
        "DISABLE_CONSOLE_OUTPUT": "false"
      }
    },
    "n8n-docs": {
      "type": "http",
      "url": "https://n8n.mcp.kapa.ai/"
    },
    "contextstream": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@contextstream/mcp-server@latest"
      ],
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "MCP_MODE": "stdio",
        "LOG_LEVEL": "info"
      }
    }
  }
}