{
    "name": "mcapp-ai-starter Dev Container",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "features": {
        "ghcr.io/devcontainers/features/node": {
            "version": "24"
        }
    },
    "mounts": [
        "source=${localWorkspaceFolder}/.devcontainer/.cache/npm,target=/home/vscode/.npm,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-vscode.vscode-node-azure-pack"
            ]
        }
    },
    "postCreateCommand": "mkdir -p .devcontainer/.cache/npm && python -m pip install --upgrade \"dspy[mcp]\" && corepack enable && if [ -f package.json ]; then npm ci || true; fi",
    "postStartCommand": "node --version || true",
    "remoteUser": "vscode"
}