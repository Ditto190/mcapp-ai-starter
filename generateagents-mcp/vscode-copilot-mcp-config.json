{
    "mcp": {
        "servers": [
            {
                "name": "generateagents-mcp",
                "description": "GenerateAgents.md MCP Server - Expose AGENTS.md generation as LLM-callable tools",
                "command": "bash",
                "args": [
                    "-c",
                    "cd /workspaces/mcapp-ai-starter/generateagents-mcp && uv run python server.py"
                ],
                "env": {
                    "PYTHONPATH": "/workspaces/mcapp-ai-starter",
                    "LOG_LEVEL": "INFO",
                    "PATH": "/root/.local/bin:/usr/local/bin:/usr/bin:/bin"
                },
                "disabled": false,
                "alwaysAllow": false,
                "autoConnect": true
            }
        ],
        "prompts": [
            {
                "name": "generateagents-help",
                "description": "Help text for GenerateAgents MCP tools",
                "arguments": []
            }
        ]
    },
    "copilot": {
        "advanced": {
            "debug.testingEnabled": true
        }
    }
}