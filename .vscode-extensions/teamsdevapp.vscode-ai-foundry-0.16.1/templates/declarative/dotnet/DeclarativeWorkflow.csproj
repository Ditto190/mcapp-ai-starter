<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net9.0</TargetFrameworks>
    <ProjectsDebugTargetFrameworks>net9.0</ProjectsDebugTargetFrameworks>
    <TargetFrameworks Condition="'$(Configuration)' == 'Debug'">$(ProjectsDebugTargetFrameworks)</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <UserSecretsId>5ee045b0-aea3-4f08-8d31-32d1a6f8fed0</UserSecretsId>
    <NoWarn>$(NoWarn);CA1812</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
    <InjectSharedThrow>true</InjectSharedThrow>
  </PropertyGroup>

  <ItemGroup>
		<PackageReference Include="Azure.AI.Agents.Persistent" Version="1.2.0-beta.4" />
		<PackageReference Include="Azure.AI.Projects" Version="1.0.0-beta.11" />
		<PackageReference Include="Microsoft.Agents.Workflows" Version="0.0.1-nightly-250919.1-alpha" />
		<PackageReference Include="Microsoft.Extensions.AI.Agents" Version="0.0.1-nightly-250919.1-alpha" />
    <PackageReference Include="Microsoft.Agents.Workflows.Declarative" Version="0.0.1-nightly-250919.1-alpha" />
  </ItemGroup>

</Project>
