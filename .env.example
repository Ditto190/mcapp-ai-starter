# Example .env - DO NOT store secrets in this file in the repo

POSTGRES_USER=root
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=<N8N_ENCRYPTION_KEY>
N8N_USER_MANAGEMENT_JWT_SECRET=<N8N_USER_MANAGEMENT_JWT_SECRET>
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Optional service hosts
# OLLAMA_HOST=host.docker.internal:11434


# Example entries for Anthropic and MCP proxy (don't commit real secrets)
# ANTHROPIC_API_KEY=sk-...
# MCP_ENDPOINT=https://your-n8n-domain.tld/mcp-server/http/
# MCP_TOKEN=your_mcp_access_token_here

# Placeholders for third-party API keys (store actual values in CI/Secrets)
OPENAI_API_KEY=<OPENAI_API_KEY>
GITHUB_PERSONAL_ACCESS_TOKEN=<GITHUB_PAT>
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# For Mac users running OLLAMA locally
# See https://github.com/n8n-io/self-hosted-ai-starter-kit?tab=readme-ov-file#for-mac--apple-silicon-users
# OLLAMA_HOST=host.docker.internal:11434


