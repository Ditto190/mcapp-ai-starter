# Codespaces-optimized example env (place real secrets in Codespace or GitHub secrets)

POSTGRES_USER=root
POSTGRES_PASSWORD=<CODESPACES_POSTGRES_PASSWORD>
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=<N8N_ENCRYPTION_KEY>
N8N_USER_MANAGEMENT_JWT_SECRET=<N8N_USER_MANAGEMENT_JWT_SECRET>

N8N_PORT=5678
N8N_PROTOCOL=http
# In Codespaces use the codespace host URL or the port-forwarded URL
N8N_HOST=<N8N_HOST_URL>

OLLAMA_HOST=ollama:11434

# Placeholders for tokens used by workflows
N8N_API_KEY=<N8N_API_KEY>
MCP_SERVER_URL=<MCP_SERVER_URL>
MCP_SERVER_TOKEN=<MCP_SERVER_TOKEN>
